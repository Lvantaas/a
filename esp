		local hpSizeConstraint = Instance.new("UITextSizeConstraint")
		hpSizeConstraint.MaxTextSize = 9
		hpSizeConstraint.MinTextSize = 5
		hpSizeConstraint.Parent = hpLbl

		local function UpdateHP()
			local hp = hum.Health
			local maxHp = hum.MaxHealth
			local pct = math.clamp(hp / maxHp, 0, 1)
			fill.Size = UDim2.new(pct, 0, 1, 0)
			fill.BackgroundColor3 = C3(math.floor(255 * (1 - pct)), math.floor(255 * pct), 0)
			hpLbl.Text = math.floor(hp).."/"..math.floor(maxHp)
		end
		UpdateHP()
		data.HealthConn = hum.HealthChanged:Connect(UpdateHP)
	end

