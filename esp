local function RestoreSkins()
	for _, obj in camera:GetChildren() do
		obj:SetAttribute("SkinApplied", nil)
		-- Remove surface appearances to restore default skins
		pcall(function()
			local weaponFolder = obj:FindFirstChild("Weapon")
			if weaponFolder then
				for _, part in weaponFolder:GetDescendants() do
					if part:IsA("BasePart") then
						local existing = part:FindFirstChildOfClass("SurfaceAppearance")
						if existing then existing:Destroy() end
					end
				end
			end
			local left = obj:FindFirstChild("Left Arm")
			local right = obj:FindFirstChild("Right Arm")
			for _, side in {left, right} do
				if side then
					local glove = side:FindFirstChild("Glove")
					if glove then
						local existing = glove:FindFirstChildOfClass("SurfaceAppearance")
						if existing then existing:Destroy() end
					end
				end
			end
		end)
	end
end

