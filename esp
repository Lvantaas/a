local function CreateFovCircle()
	pcall(function()
		if aimbotState.fovCircle then
			aimbotState.fovCircle:Remove()
			aimbotState.fovCircle = nil
		end
		if not Cfg.AimbotEnabled then return end
		local circle = Drawing.new("Circle")
		circle.Position = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
		circle.Radius = Cfg.AimbotFov
		circle.Color = Cfg.AimbotFovColor
		circle.Thickness = 1.5
		circle.Transparency = 0.6
		circle.Filled = false
		circle.Visible = Cfg.AimbotShowFov
		aimbotState.fovCircle = circle
	end)
end

local function RemoveFovCircle()
	pcall(function()
		if aimbotState.fovCircle then
			aimbotState.fovCircle:Remove()
			aimbotState.fovCircle = nil
		end
	end)
end

local function HasLineOfSight(targetPart, targetCharacter)
	if not Cfg.AimbotWallCheck then return true end
	local origin = camera.CFrame.Position
	local direction = targetPart.Position - origin
	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {LP.Character, camera}
	params.FilterType = Enum.RaycastFilterType.Blacklist
	local result = Workspace:Raycast(origin, direction, params)
	return not result or result.Instance:IsDescendantOf(targetCharacter)
end

function isTeammateVisuals(player)
	if isArsenal and Cfg.TeamCheckVisuals then
		if player.Team and LP.Team then
			return player.Team == LP.Team
		end
	end
	return false
end

function isTeammateAimbot(player)
	if isArsenal and Cfg.TeamCheckAimbot then
		if player.Team and LP.Team then
			return player.Team == LP.Team
		end
