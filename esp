        for _, weaponName in ipairs(cat.weapons) do
            local skinKey = skinPrefix .. weaponName
            local wFolder = SkinsFolder:FindFirstChild(weaponName)
            if wFolder then
                local opts = {}
                for _, sk in ipairs(wFolder:GetChildren()) do
                    table.insert(opts, sk.Name)
                end
                if #opts > 0 then
