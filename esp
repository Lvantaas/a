local function selectCategory(catName)
	activeCategory = catName
	for name, btn in pairs(categoryButtons) do
		local active = (name == catName)
		local targetColor = active and C3(255, 255, 255) or C3(150, 150, 160)
		local targetBg = active and C3(255, 255, 255) or C3(16, 16, 22)
		local btnGrad = btn:FindFirstChildOfClass("UIGradient")
		if btnGrad then btnGrad.Enabled = active end
		
		TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
			TextColor3 = targetColor,
			BackgroundColor3 = targetBg
		}):Play()
	end
	local col = Cfg[catName]
	rSlider.SetValue(math.round(col.R * 255))
	gSlider.SetValue(math.round(col.G * 255))
	bSlider.SetValue(math.round(col.B * 255))
	rSlider.Value = math.round(col.R * 255)
	gSlider.Value = math.round(col.G * 255)
	bSlider.Value = math.round(col.B * 255)
	previewSwatch.BackgroundColor3 = col
end

