	barFill.BorderSizePixel = 0
	barFill.Parent = barBg
	Instance.new("UICorner", barFill).CornerRadius = UDim.new(0, 2)
	AddPremiumGradient(barFill)

	-- Play Fade-in animations
	local tIn = TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	TweenService:Create(mainText, tIn, {TextTransparency = 0}):Play()
	TweenService:Create(mainStroke, tIn, {Transparency = 0.5}):Play()
	TweenService:Create(subText, tIn, {TextTransparency = 0}):Play()
	TweenService:Create(subStroke, tIn, {Transparency = 0.6}):Play()
	TweenService:Create(statusLog, tIn, {TextTransparency = 0}):Play()
	task.wait(0.6)

	-- Step-by-step injection logs simulation
	local steps = {
		{prog = 0.25, log = "Injecting core hooks..."},
		{prog = 0.50, log = "Decrypting highlight engine modules..."},
		{prog = 0.75, log = "Bypassing aimbot vector calculation structures..."},
		{prog = 1.00, log = "Client components successfully loaded!"}
	}

	for _, step in ipairs(steps) do
		statusLog.Text = step.log
		TweenService:Create(barFill, TweenInfo.new(0.6, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
			Size = UDim2.new(step.prog, 0, 1, 0)
