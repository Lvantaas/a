			end
			if WatermarkStroke then WatermarkStroke.Color = color end
			if AccentBar then AccentBar.BackgroundColor3 = color end
			if AccentCover then AccentCover.BackgroundColor3 = color end
		else
			if WatermarkStroke and WatermarkStroke.Color ~= C3(168, 85, 247) then
				WatermarkStroke.Color = C3(168, 85, 247)
				AccentBar.BackgroundColor3 = C3(168, 85, 247)
				AccentCover.BackgroundColor3 = C3(168, 85, 247)
			end
		end
	end
end)

-- ===== KEYBIND TO TOGGLE MENU =====
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Cfg.MenuKey then
		ToggleMenu(not menuOpen)
	end
end)

-- ===== UNLOAD FUNCTION =====
_G.UnloadChams = function()
	isRunning = false

	aimbotState.active = false
	aimbotState.currentTarget = nil
	RemoveFovCircle()

	pcall(function() RunService:UnbindFromRenderStep("LsantasAimbot") end)

	for _, conn in pairs(aimbotState.connections) do
		if conn and conn.Disconnect then conn:Disconnect() end
	end
	aimbotState.connections = {}

	if Cons.Add then Cons.Add:Disconnect() end
	if Cons.Remove then Cons.Remove:Disconnect() end
	for _, playerCons in pairs(Cons) do
		if type(playerCons) == "table" then
			for _, conn in pairs(playerCons) do
				if conn.Disconnect then conn:Disconnect() end
			end
		elseif playerCons.Disconnect then
			playerCons:Disconnect()
		end
	end
	ClearAll()
	if Container then Container:Destroy() end
	if WatermarkGui then WatermarkGui:Destroy() end
	_G.UnloadChams = nil
	_G.RefreshChams = nil
	ScreenGui:Destroy()
end
