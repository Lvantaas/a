local function handleAction(actionName, inputState, inputObject)
    if not spawned or not animator or not isAlive() then
        return Enum.ContextActionResult.Pass
    end

    if actionName == ACTION_INSPECT then
        if inputState ~= Enum.UserInputState.Begin then
            return Enum.ContextActionResult.Pass
        end
        if (equipAnim and equipAnim.IsPlaying) or inspecting or swinging then
            return Enum.ContextActionResult.Pass
        end

        inspecting = true
        if idleAnim then idleAnim:Stop() end
        inspectAnim:Play()
        inspectAnim.Stopped:Once(function() inspecting = false end)

    elseif actionName == ACTION_ATTACK then
        if inputState == Enum.UserInputState.Begin then
            lmbHeld = true
            task.spawn(function()
                while lmbHeld and spawned do
                    if inspecting then
                        inspecting = false
                        if inspectAnim then inspectAnim:Stop() end
                    end

                    local currentTime = os.clock()
                    if not (equipAnim and equipAnim.IsPlaying) and (currentTime - lastLightAttackTime >= ATTACK_COOLDOWN) then
                        lastLightAttackTime = currentTime

                        if Swing1Anim and Swing1Anim.IsPlaying then Swing1Anim:Stop() end
                        if Swing2Anim and Swing2Anim.IsPlaying then Swing2Anim:Stop() end

                        swinging = true
                        if idleAnim then idleAnim:Stop() end

                        local lightAnims = {Swing1Anim, Swing2Anim}
                        local chosenAnim = lightAnims[math.random(1, #lightAnims)]
                        local soundFolder = (chosenAnim == Swing1Anim and "HitTwo") or "HitThree"

                        chosenAnim:Play()
                        local s = playSound(soundFolder, "1")
                        if s then s.Volume = 5 end

                        task.wait(ATTACK_COOLDOWN)
                        swinging = false
                    else
                        task.wait(0.02)
                    end
                end
            end)
        elseif inputState == Enum.UserInputState.End or inputState == Enum.UserInputState.Cancel then
            lmbHeld = false
        end

    elseif actionName == ACTION_HEAVY then
        if inputState == Enum.UserInputState.Begin then
            rmbHeld = true
            task.spawn(function()
                while rmbHeld and spawned do
                    if inspecting then
                        inspecting = false
                        if inspectAnim then inspectAnim:Stop() end
                    end

                    local currentTime = os.clock()
                    if not (equipAnim and equipAnim.IsPlaying) and (currentTime - lastHeavyAttackTime >= HEAVY_COOLDOWN) then
                        lastHeavyAttackTime = currentTime

                        if HeavySwingAnim and HeavySwingAnim.IsPlaying then HeavySwingAnim:Stop() end

                        swinging = true
                        if idleAnim then idleAnim:Stop() end

                        HeavySwingAnim:Play()
                        local s = playSound("HitOne", "1")
                        if s then s.Volume = 5 end

                        task.wait(HEAVY_COOLDOWN)
                        swinging = false
                    else
                        task.wait(0.02)
                    end
                end
            end)
        elseif inputState == Enum.UserInputState.End or inputState == Enum.UserInputState.Cancel then
            rmbHeld = false
        end
    end

    return Enum.ContextActionResult.Pass
end

