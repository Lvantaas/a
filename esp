				local isChatting = UserInputService:GetFocusedTextBox() ~= nil
				if isSpaceDown and not isChatting then
					hum:ChangeState(Enum.HumanoidStateType.Jumping)
				end
			end
		end
	end
end)

-- ===== SKELETON ESP LOOP =====
local skeletonConnection
local function SetupSkeletonLoop()
	if skeletonConnection then skeletonConnection:Disconnect() end
	skeletonConnection = RunService.RenderStepped:Connect(function()
		if not isRunning then return end
		local hue = (tick() * 0.15) % 1
		local rainbowColor = HSV(hue, 0.8, 1)
		
		for Plr, data in pairs(Chams) do
			local char = Plr.Character
			local isTeammate = isTeammateVisuals(Plr)
			local showSkeleton = Cfg.Enabled and Cfg.SkeletonEspEnabled and char and char.Parent and not isTeammate
			
			if showSkeleton then
				if not data.SkeletonLines then
					CreateSkeletonLines(data, char)
				end
				
				if data.SkeletonLines then
					local color = Cfg.VisualsRGB and rainbowColor or Cfg.SkeletonColor
					for _, item in ipairs(data.SkeletonLines) do
						local p1 = char:FindFirstChild(item.part1)
						local p2 = char:FindFirstChild(item.part2)
						if p1 and p2 then
							local pos1, onScreen1 = camera:WorldToViewportPoint(p1.Position)
							local pos2, onScreen2 = camera:WorldToViewportPoint(p2.Position)
							
							if onScreen1 and onScreen2 then
								item.line.From = Vector2.new(pos1.X, pos1.Y)
								item.line.To = Vector2.new(pos2.X, pos2.Y)
								item.line.Color = color
								item.line.Visible = true
							else
								item.line.Visible = false
							end
						else
							item.line.Visible = false
						end
					end
				end
			else
				if data.SkeletonLines then
					for _, item in ipairs(data.SkeletonLines) do
						pcall(function() item.line:Remove() end)
					end
					data.SkeletonLines = nil
				end
			end
		end
	end)
end
SetupSkeletonLoop()

