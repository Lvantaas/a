-- Dynamic name resolver for hotkeys and GUI indicators
local function GetInputName(input)
	if not input then return "None" end
	if typeof(input) == "EnumItem" then
		if input.Name == "MouseButton1" or input == Enum.UserInputType.MouseButton1 then
			return "LMB"
		elseif input.Name == "MouseButton2" or input == Enum.UserInputType.MouseButton2 then
			return "RMB"
		elseif input.Name == "MouseButton3" or input == Enum.UserInputType.MouseButton3 then
			return "MMB"
		else
			return input.Name
		end
	elseif typeof(input) == "Instance" and input:IsA("InputObject") then
		if input.UserInputType == Enum.UserInputType.Keyboard then
			return input.KeyCode.Name
		elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
			return "LMB"
		elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
			return "RMB"
		elseif input.UserInputType == Enum.UserInputType.MouseButton3 then
			return "MMB"
		else
			return input.UserInputType.Name
		end
	end
	return tostring(input)
end

