                            closeDD()
                            for _, obj in ipairs(camera:GetChildren()) do
                                obj:SetAttribute("SkinApplied", nil)
                                applyWeaponSkin(obj)
                            end
                        end)
                    end
                end
            end
        end
    end

    -- Kategori butonlarını oluştur
    for i, cat in ipairs(categories) do
        local catBtn = Instance.new("TextButton")
        catBtn.Size = UDim2.new(0, 56, 0, 28)
        catBtn.BackgroundColor3 = (i == 1) and cat.color or C3(24, 24, 32)
        catBtn.Text = cat.icon
        catBtn.Font = Enum.Font.GothamBold
        catBtn.TextSize = 13
        catBtn.BorderSizePixel = 0
        catBtn.ZIndex = 3
        catBtn.Parent = catCard

        local catBtnCorner = Instance.new("UICorner")
        catBtnCorner.CornerRadius = UDim.new(0, 6)
        catBtnCorner.Parent = catBtn

        local catBtnStroke = Instance.new("UIStroke")
        catBtnStroke.Thickness = 1
        catBtnStroke.Color = (i == 1) and cat.color or C3(40, 40, 50)
        catBtnStroke.Parent = catBtn

        catButtons[i] = { btn = catBtn, stroke = catBtnStroke, cat = cat }

        catBtn.MouseButton1Click:Connect(function()
            -- Önceki butonu sıfırla
            local prev = catButtons[activeCatIndex]
            if prev then
                TweenService:Create(prev.btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {BackgroundColor3 = C3(24, 24, 32)}):Play()
                prev.stroke.Color = C3(40, 40, 50)
            end
            -- Yeni butonu vurgula
            activeCatIndex = i
            TweenService:Create(catBtn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {BackgroundColor3 = cat.color}):Play()
            catBtnStroke.Color = cat.color
            -- Listeyi yenile
            BuildSkinList(i)
        end)

        catBtn.MouseEnter:Connect(function()
            if activeCatIndex ~= i then
                TweenService:Create(catBtn, TweenInfo.new(0.1), {BackgroundColor3 = C3(32, 32, 44)}):Play()
            end
        end)
        catBtn.MouseLeave:Connect(function()
            if activeCatIndex ~= i then
                TweenService:Create(catBtn, TweenInfo.new(0.1), {BackgroundColor3 = C3(24, 24, 32)}):Play()
            end
        end)
    end

    -- TÜM kategorilerdeki tüm silahlar için varsayılan skin seçimlerini önceden doldur
    -- (Menü açılmadan da skin uygulanabilsin)
    for _, cat in ipairs(categories) do
        local pfx = cat.prefix or ""
        for _, weaponName in ipairs(cat.weapons) do
            local skinKey = pfx .. weaponName
            if not SelectedSkins[skinKey] then
                local wFolder = SkinsFolder:FindFirstChild(weaponName)
                if wFolder then
                    local children = wFolder:GetChildren()
                    if #children > 0 then
                        SelectedSkins[skinKey] = children[1].Name
                    end
                end
            end
        end
    end

    -- Başlangıçta bıçakları göster
    BuildSkinList(1)
end

