end

-- Check if locked target is still valid
local function IsTargetValid(player)
	if not player or not player.Character or not player.Parent then return false, nil end
	if isTeammateAimbot(player) then return false, nil end

	local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid or humanoid.Health <= 0 then return false, nil end

	local partName = Cfg.AimbotTargetPart
	local part = player.Character:FindFirstChild(partName)
	if not part then
		if partName == "UpperTorso" or partName == "LowerTorso" then
			part = player.Character:FindFirstChild("Torso")
		elseif partName == "Torso" then
			part = player.Character:FindFirstChild("UpperTorso") or player.Character:FindFirstChild("LowerTorso")
		end
	end
	if not part then
		part = player.Character:FindFirstChild("Head")
	end
	if not part then return false, nil end

	local screenPos, onScreen = camera:WorldToViewportPoint(part.Position)
	if not onScreen or screenPos.Z <= 0 then return false, nil end

	local viewportCenter = camera.ViewportSize / 2
	local dist = (Vector2.new(screenPos.X, screenPos.Y) - viewportCenter).Magnitude
	if dist > Cfg.AimbotFov then return false, nil end

	if not HasLineOfSight(part, player.Character) then return false, nil end

	return true, part
end

local function GetClosestPlayer()
	local closestPlayer = nil
	local shortestDistance = Cfg.AimbotFov
	local viewportCenter = camera.ViewportSize / 2

	for _, player in pairs(Players:GetPlayers()) do
		if player ~= LP then
			local valid, part = IsTargetValid(player)
			if valid and part then
				local screenPos = camera:WorldToViewportPoint(part.Position)
				local dist = (Vector2.new(screenPos.X, screenPos.Y) - viewportCenter).Magnitude
				if dist < shortestDistance then
					shortestDistance = dist
					closestPlayer = player
				end
			end
		end
	end
	return closestPlayer
end

-- High fidelity mouse simulation + CFrame fallback aiming
local function AimAt(targetPos, dt)
	local s = math.clamp(Cfg.AimbotSmoothness, 1, 20)
	
	if Cfg.UseMouseSimulation and hasMouseSim then
		local screenPos, onScreen = camera:WorldToViewportPoint(targetPos)
		if onScreen then
			local viewportCenter = camera.ViewportSize / 2
			local diff = Vector2.new(screenPos.X, screenPos.Y) - viewportCenter
			
			local scale = math.clamp(dt * 60, 0.1, 3.0)
			local moveX = (diff.X / s) * scale
			local moveY = (diff.Y / s) * scale
			
			mousemoverel(moveX, moveY)
		end
	else
		if s == 1 then
			camera.CFrame = CFrame.lookAt(camera.CFrame.Position, targetPos)
		else
			local targetCFrame = CFrame.lookAt(camera.CFrame.Position, targetPos)
			local speed = 30 / s
			local alpha = math.clamp(speed * dt, 0, 1)
			camera.CFrame = camera.CFrame:Lerp(targetCFrame, alpha)
		end
	end
end

-- Bind target-holding key input bindings
local function SetupAimbotInput()
	pcall(function()
		if aimbotState.connections.inputBegan then aimbotState.connections.inputBegan:Disconnect() end
		if aimbotState.connections.inputEnded then aimbotState.connections.inputEnded:Disconnect() end

		aimbotState.connections.inputBegan = UserInputService.InputBegan:Connect(function(input, gpe)
			if gpe then return end
			local k = Cfg.AimbotKey
			local matches = (input.UserInputType == k) or (input.KeyCode == k)
			if matches then
				if Cfg.AimbotMode == "Toggle" then
					aimbotState.active = not aimbotState.active
					if not aimbotState.active then
						aimbotState.currentTarget = nil
					end
				else
					aimbotState.active = true
				end
			end
		end)

		aimbotState.connections.inputEnded = UserInputService.InputEnded:Connect(function(input)
			if Cfg.AimbotMode == "Hold" then
				local k = Cfg.AimbotKey
				local matches = (input.UserInputType == k) or (input.KeyCode == k)
				if matches then
					aimbotState.active = false
					aimbotState.currentTarget = nil
				end
			end
		end)
	end)
end

-- Main render aiming thread
local function SetupAimbotLoop()
	pcall(function()
		pcall(function() RunService:UnbindFromRenderStep("LsantasAimbot") end)

		RunService:BindToRenderStep("LsantasAimbot", Enum.RenderPriority.Camera.Value + 1, function(dt)
			pcall(function()
				if not Cfg.AimbotEnabled then
					if aimbotState.fovCircle then aimbotState.fovCircle.Visible = false end
					return
				end

				if aimbotState.fovCircle then
					aimbotState.fovCircle.Position = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
					aimbotState.fovCircle.Radius = Cfg.AimbotFov
					aimbotState.fovCircle.Color = Cfg.AimbotFovColor
					aimbotState.fovCircle.Visible = Cfg.AimbotShowFov
				end

				if aimbotState.active then
					local target = aimbotState.currentTarget
					local isValid, targetPart = false, nil
					if target then
						isValid, targetPart = IsTargetValid(target)
					end

					if not isValid then
						target = GetClosestPlayer()
						if target then
							aimbotState.currentTarget = target
							isValid, targetPart = IsTargetValid(target)
						else
							aimbotState.currentTarget = nil
						end
					end

					if target and isValid and targetPart then
						local velocity = Vector3.new(0, 0, 0)
						local root = target.Character:FindFirstChild("HumanoidRootPart")
						if root then
							velocity = root.AssemblyLinearVelocity or root.Velocity or velocity
						end

						local s = math.clamp(Cfg.AimbotSmoothness, 1, 20)
						local targetPos = targetPart.Position

						if Cfg.AimbotPrediction and s > 1 and velocity.Magnitude > 0 then
							local predictionTime = s / 30
							local predictionOffset = velocity * predictionTime * Cfg.AimbotPredictionFactor
							if predictionOffset.Magnitude > 15 then
								predictionOffset = predictionOffset.Unit * 15
							end
							targetPos = targetPos + predictionOffset
						end

						AimAt(targetPos, dt)
					end
				end
			end)
		end)
	end)
end

pcall(CreateFovCircle)
pcall(SetupAimbotInput)
pcall(SetupAimbotLoop)

