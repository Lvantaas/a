local function updateColorsFromSliders()
	local r = (rSlider.Value or 0) / 255
	local g = (gSlider.Value or 0) / 255
	local b = (bSlider.Value or 0) / 255
	local col = Color3.new(r, g, b)
	Cfg[activeCategory] = col
	previewSwatch.BackgroundColor3 = col

	if not Cfg.VisualsRGB then
		if activeCategory == "ChamColor" then
			for _, data in pairs(Chams) do
				if data.Highlight then data.Highlight.FillColor = col end
			end
		elseif activeCategory == "OutlineColor" then
			for _, data in pairs(Chams) do
				if data.Highlight then data.Highlight.OutlineColor = col end
			end
		elseif activeCategory == "NameColor" then
			for _, data in pairs(Chams) do
				if data.NameLabel then data.NameLabel.TextColor3 = col end
			end
		elseif activeCategory == "SkeletonColor" then
			-- Handled dynamically in skeleton loop
		elseif activeCategory == "AimbotFovColor" then
			if aimbotState.fovCircle then aimbotState.fovCircle.Color = col end
		end
	else
		if activeCategory == "OutlineColor" then
			for _, data in pairs(Chams) do
				if data.Highlight then data.Highlight.OutlineColor = col end
			end
		end
	end
end

