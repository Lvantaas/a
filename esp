		hpCorner.Parent = hpFrame

		local stroke = Instance.new("UIStroke")
		stroke.Thickness = 1
		stroke.Color = C3(40, 40, 40)
		stroke.Parent = hpFrame
		data.HealthStroke = stroke

		local fill = Instance.new("Frame")
		fill.Name = "Fill"
		fill.BackgroundColor3 = C3(80, 200, 80)
		fill.BorderSizePixel = 0
		fill.Parent = hpFrame

		local fillCorner = Instance.new("UICorner")
		fillCorner.CornerRadius = UDim.new(0, 2)
		fillCorner.Parent = fill

		local hpLbl = Instance.new("TextLabel")
		hpLbl.Size = UDim2.new(1, 0, 1, 0)
		hpLbl.BackgroundTransparency = 1
		hpLbl.Text = math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)
		hpLbl.TextColor3 = C3(255, 255, 255)
		hpLbl.TextStrokeTransparency = 0.5
		hpLbl.Font = Enum.Font.Gotham
		hpLbl.TextScaled = true
		hpLbl.Parent = hpFrame

		local hpSizeConstraint = Instance.new("UITextSizeConstraint")
		hpSizeConstraint.MaxTextSize = 9
		hpSizeConstraint.MinTextSize = 5
		hpSizeConstraint.Parent = hpLbl

		local function UpdateHP()
			local hp = hum.Health
			local maxHp = hum.MaxHealth
			local pct = math.clamp(hp / maxHp, 0, 1)
			fill.Size = UDim2.new(pct, 0, 1, 0)
			fill.BackgroundColor3 = C3(math.floor(255 * (1 - pct)), math.floor(255 * pct), 0)
			hpLbl.Text = math.floor(hp).."/"..math.floor(maxHp)
		end
		UpdateHP()
		data.HealthConn = hum.HealthChanged:Connect(UpdateHP)
	end

	Chams[Plr] = data
end

_G.RefreshChams = function()
	ClearAll()
	if not Cfg.Enabled then return end
	for _, v in next, Players:GetPlayers() do
		if v ~= LP and v.Character then Paint(v.Character, v) end
	end
end

local function Hook(Plr)
	if Plr == LP then return end
	if Cons[Plr] then
		for _, c in pairs(Cons[Plr]) do c:Disconnect() end
	end
	Cons[Plr] = {}
	table.insert(Cons[Plr], Plr.CharacterAdded:Connect(function(c)
		c:WaitForChild("Humanoid", 5)
		task.wait(0.15)
		if Cfg.Enabled then Paint(c, Plr) end
	end))
	table.insert(Cons[Plr], Plr.CharacterRemoving:Connect(function()
		ClearPlayer(Plr)
	end))
	if Plr.Character and Cfg.Enabled then Paint(Plr.Character, Plr) end
end

for _, v in next, Players:GetPlayers() do Hook(v) end

Cons.Add = Players.PlayerAdded:Connect(Hook)
Cons.Remove = Players.PlayerRemoving:Connect(function(Plr)
	ClearPlayer(Plr)
	if Cons[Plr] then
		for _, c in pairs(Cons[Plr]) do c:Disconnect() end
		Cons[Plr] = nil
	end
end)

-- ===== PERIODIC AUTO-HEAL & CLEANUP LOOP =====
task.spawn(function()
	while task.wait(1) do
		if not isRunning then break end
		if not Container or not Container.Parent then
			Container = workspace.CurrentCamera:FindFirstChild("LsantasVisuals")
			if not Container or not Container.Parent then
				Container = Instance.new("Folder")
				Container.Name = "LsantasVisuals"
				Container.Parent = workspace.CurrentCamera
			end
		end
		if Cfg.Enabled then
			for _, v in ipairs(Players:GetPlayers()) do
				if v ~= LP then
					pcall(function()
						local char = v.Character
						if char and char.Parent then
							local hum = char:FindFirstChildOfClass("Humanoid")
							if hum and hum.Health > 0 then
								local data = Chams[v]
								local hasHighlight = data and data.Highlight and data.Highlight.Parent == Container
								if not data or not hasHighlight then
									Paint(char, v)
								end
							else
								ClearPlayer(v)
							end
						else
							ClearPlayer(v)
						end
					end)
				end
			end
		else
			ClearAll()
		end
	end
end)

