local function Hook(Plr)
	if Plr == LP then return end
	if Cons[Plr] then
		for _, c in pairs(Cons[Plr]) do c:Disconnect() end
	end
	Cons[Plr] = {}
	table.insert(Cons[Plr], Plr.CharacterAdded:Connect(function(c)
		c:WaitForChild("Humanoid", 5)
		task.wait(0.15)
		if Cfg.Enabled and not isTeammateVisuals(Plr) then Paint(c, Plr) end
	end))
	table.insert(Cons[Plr], Plr.CharacterRemoving:Connect(function()
		ClearPlayer(Plr)
	end))
	if Plr.Character and Cfg.Enabled and not isTeammateVisuals(Plr) then Paint(Plr.Character, Plr) end
end

for _, v in next, Players:GetPlayers() do Hook(v) end

Cons.Add = Players.PlayerAdded:Connect(Hook)
Cons.Remove = Players.PlayerRemoving:Connect(function(Plr)
	ClearPlayer(Plr)
	if Cons[Plr] then
		for _, c in pairs(Cons[Plr]) do c:Disconnect() end
		Cons[Plr] = nil
	end
end)

