-- Real-time FPS update loop
task.spawn(function()
	local lastTime = tick()
	local frameCount = 0
	while task.wait() do
		if not isRunning then break end
		frameCount = frameCount + 1
		local currentTime = tick()
		if currentTime - lastTime >= 1 then
			local fps = math.round(frameCount / (currentTime - lastTime))
			if WatermarkLabel and WatermarkLabel.Parent then
				WatermarkLabel.Text = "Lsantas Hack Client  |  FPS: " .. fps
			end
			frameCount = 0
			lastTime = currentTime
		end
	end
end)

