                        ddList.Visible = false
                        ddList.Size = UDim2.new(0, 0, 0, 0)
                        if activeDropdown == closeDD then
                            activeDropdown = nil
                        end
                    end

                    local function toggleDD()
                        -- Önce varsa başka açık dropdown'u kapat
                        if activeDropdown and activeDropdown ~= closeDD then
                            activeDropdown()
                        end

                        ddOpen = not ddOpen
                        if ddOpen then
                            local h = math.clamp(#opts * 20 + 2, 20, 110)
                            local btnAbs = ddBtn.AbsolutePosition
                            local cardAbs = skinListCard.AbsolutePosition

                            -- Butonun skinListCard'a göre konumu
                            local relX = btnAbs.X - cardAbs.X
                            local relY = btnAbs.Y - cardAbs.Y

                            -- Yukarı mı aşağı mı açılsın?
                            local cardH = skinListCard.AbsoluteSize.Y
                            local openUp = (relY + 22 + h) > cardH

                            if openUp then
                                ddList.Position = UDim2.new(0, relX, 0, relY - h - 2)
                            else
                                ddList.Position = UDim2.new(0, relX, 0, relY + 22 + 2)
                            end

                            ddList.Size = UDim2.new(0, ddBtn.AbsoluteSize.X, 0, h)
                            ddList.CanvasSize = UDim2.new(0, 0, 0, #opts * 20 + 2)
                            ddList.Visible = true
                            activeDropdown = closeDD
                        else
