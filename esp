-- ===== CHAMS & ESP LOGIC =====

local function ClearPlayer(Plr)
	local data = Chams[Plr]
	if data then
		if data.Highlight then data.Highlight:Destroy() end
		if data.NameGui then data.NameGui:Destroy() end
		if data.HealthGui then data.HealthGui:Destroy() end
		if data.HealthConn then data.HealthConn:Disconnect() end
		Chams[Plr] = nil
	end
end

local function ClearAll()
	for plr in pairs(Chams) do
		ClearPlayer(plr)
	end
end

local function Paint(Chr, Plr)
	if not Chr or not Cfg.Enabled then return end
	
	-- Clear old chams first if they exist
	ClearPlayer(Plr)

	local data = {}

	-- Highlight (Chams)
	local H = Instance.new("Highlight")
	H.Name = Tag
	H.FillColor = Cfg.ChamColor
	H.OutlineColor = Cfg.OutlineColor
	H.FillTransparency = Cfg.FillTr
	H.OutlineTransparency = Cfg.OutTr
	H.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	H.Adornee = Chr
	H.Parent = Container
	data.Highlight = H

	-- Wait for head or default part to attach text labels
	local adornee = Chr:FindFirstChild("Head") or Chr:FindFirstChild("HumanoidRootPart") or Chr.PrimaryPart or Chr

	-- Billboard Name
	local bg = Instance.new("BillboardGui")
	bg.Name = Tag.."Name"
	bg.Size = UDim2.new(0, 100, 0, 24)
	bg.StudsOffset = Vector3.new(0, 3.8, 0)
	bg.AlwaysOnTop = true
	bg.ResetOnSpawn = false
	bg.Enabled = Cfg.ShowNames
	bg.Adornee = adornee
	bg.Parent = Container
	data.NameGui = bg

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(1, 0, 1, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = Plr.DisplayName
	lbl.TextColor3 = Cfg.NameColor
	lbl.TextStrokeTransparency = 1
	lbl.Font = Enum.Font.GothamBold
	lbl.TextSize = 14
	lbl.Parent = bg
	data.NameLabel = lbl

	local lblStroke = Instance.new("UIStroke")
	lblStroke.Thickness = 1
	lblStroke.Color = C3(0, 0, 0)
	lblStroke.Transparency = 0.4
	lblStroke.Parent = lbl
	data.NameStroke = lblStroke

	-- Billboard Health Bar
	local hum = Chr:FindFirstChildOfClass("Humanoid")
	if hum then
		local hpBg = Instance.new("BillboardGui")
		hpBg.Name = Tag.."HP"
		hpBg.Size = UDim2.new(0, 80, 0, 10)
		hpBg.StudsOffset = Vector3.new(0, -3.5, 0)
		hpBg.AlwaysOnTop = true
		hpBg.ResetOnSpawn = false
		hpBg.Enabled = Cfg.ShowHealth
		hpBg.Adornee = adornee
		hpBg.Parent = Container
		data.HealthGui = hpBg

		local hpFrame = Instance.new("Frame")
		hpFrame.Size = UDim2.new(1, 0, 1, 0)
		hpFrame.BackgroundColor3 = C3(15,15,15)
		hpFrame.BackgroundTransparency = 0.25
		hpFrame.BorderSizePixel = 0
		hpFrame.Parent = hpBg

		local hpCorner = Instance.new("UICorner")
		hpCorner.CornerRadius = UDim.new(0, 2)
		hpCorner.Parent = hpFrame

		local stroke = Instance.new("UIStroke")
		stroke.Thickness = 1
		stroke.Color = C3(40,40,40)
		stroke.Parent = hpFrame
		data.HealthStroke = stroke

		local fill = Instance.new("Frame")
		fill.Name = "Fill"
		fill.BackgroundColor3 = C3(80,200,80)
		fill.BorderSizePixel = 0
		fill.Parent = hpFrame

		local fillCorner = Instance.new("UICorner")
		fillCorner.CornerRadius = UDim.new(0, 2)
		fillCorner.Parent = fill

		local hpLbl = Instance.new("TextLabel")
		hpLbl.Size = UDim2.new(1, 0, 1, 0)
		hpLbl.BackgroundTransparency = 1
		hpLbl.Text = math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)
		hpLbl.TextColor3 = C3(255, 255, 255)
		hpLbl.TextStrokeTransparency = 0.5
		hpLbl.Font = Enum.Font.Gotham
		hpLbl.TextSize = 9
		hpLbl.Parent = hpFrame

		local function UpdateHP()
			local hp = hum.Health
			local maxHp = hum.MaxHealth
			local pct = math.clamp(hp / maxHp, 0, 1)
			fill.Size = UDim2.new(pct, 0, 1, 0)
			fill.BackgroundColor3 = C3(
				math.floor(255 * (1 - pct)),
				math.floor(255 * pct),
				0
			)
			hpLbl.Text = math.floor(hp).."/"..math.floor(maxHp)
		end
		UpdateHP()
		local conn = hum.HealthChanged:Connect(UpdateHP)
		data.HealthConn = conn
	end

	Chams[Plr] = data
end

_G.RefreshChams = function()
	ClearAll()
	if not Cfg.Enabled then return end
	for _, v in next, P:GetPlayers() do
		if v ~= LP and v.Character then Paint(v.Character, v) end
	end
end

local function Hook(Plr)
	if Plr == LP then return end
	if Cons[Plr] then
		for _, c in pairs(Cons[Plr]) do c:Disconnect() end
	end
	
	Cons[Plr] = {}
	
	table.insert(Cons[Plr], Plr.CharacterAdded:Connect(function(c)
		c:WaitForChild("Humanoid", 5)
		task.wait(0.15)
		if Cfg.Enabled then Paint(c, Plr) end
	end))
	
	table.insert(Cons[Plr], Plr.CharacterRemoving:Connect(function()
		ClearPlayer(Plr)
	end))
	
	if Plr.Character and Cfg.Enabled then Paint(Plr.Character, Plr) end
end

-- Hook existing players
for _, v in next, P:GetPlayers() do Hook(v) end

-- Hook incoming & outgoing players
Cons.Add = P.PlayerAdded:Connect(Hook)
Cons.Remove = P.PlayerRemoving:Connect(function(Plr)
	ClearPlayer(Plr)
	if Cons[Plr] then
		for _, c in pairs(Cons[Plr]) do c:Disconnect() end
		Cons[Plr] = nil
	end
end)

-- ===== PERIODIC AUTO-HEAL & CLEANUP LOOP (Bypasses anti-cheats & round clears) =====
task.spawn(function()
	while task.wait(1) do
		if not isRunning then break end
		
		-- Recreate container if camera cleared it
		if not Container or not Container.Parent then
			Container = workspace.CurrentCamera:FindFirstChild("LsantasVisuals")
			if not Container or not Container.Parent then
				Container = Instance.new("Folder")
				Container.Name = "LsantasVisuals"
				Container.Parent = workspace.CurrentCamera
			end
		end

		if Cfg.Enabled then
			for _, v in ipairs(P:GetPlayers()) do
				if v ~= LP then
					pcall(function()
						local char = v.Character
						if char and char.Parent then
							local hum = char:FindFirstChildOfClass("Humanoid")
							if hum and hum.Health > 0 then
								local data = Chams[v]
								local hasHighlight = data and data.Highlight and data.Highlight.Parent == Container
								if not data or not hasHighlight then
									Paint(char, v)
								end
							else
								ClearPlayer(v)
							end
						else
							ClearPlayer(v)
						end
					end)
				end
			end
		else
			ClearAll()
		end
	end
end)

