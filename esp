-- Switch Tab with Slide Transition & Gradient Activation
local function SwitchTab(tabName)
	for name, contentFrame in pairs(Tabs) do
		if name == tabName then
			contentFrame.Visible = true
			contentFrame.Position = UDim2.new(0, 10, 0, 25)
			TweenService:Create(contentFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Position = UDim2.new(0, 10, 0, 10)
			}):Play()
		else
			contentFrame.Visible = false
		end
	end
	for name, btn in pairs(TabButtons) do
		local active = (name == tabName)
		local targetColor = active and C3(255, 255, 255) or C3(150, 150, 160)
		local targetBg = active and C3(255, 255, 255) or C3(16, 16, 22)
		local btnGrad = btn:FindFirstChildOfClass("UIGradient")
		
		if btnGrad then
			btnGrad.Enabled = active
		end
		
		TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
			TextColor3 = targetColor,
			BackgroundColor3 = targetBg
		}):Play()
	end
end

